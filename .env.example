# ──────────────────────────────────────────────────────────────────────────────
# Dive Lovers — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha com os valores reais.
# .env.local está no .gitignore e nunca vai pro repositório.
# ──────────────────────────────────────────────────────────────────────────────

# Meta Pixel ID
# Onde obter: business.facebook.com → Gerenciador de Eventos → Pixels
# Formato: string numérica (ex: 1234567890123)
NEXT_PUBLIC_META_PIXEL_ID=

# Google Analytics 4 — Measurement ID
# Onde obter: analytics.google.com → Admin → Fluxos de dados → seu fluxo → ID de medição
# Formato: G-XXXXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Número do WhatsApp em formato internacional (sem espaços, sem +)
# Onde obter: seu WhatsApp Business
# Formato: código do país + DDD + número (ex: 5511982023600)
NEXT_PUBLIC_WHATSAPP_NUMBER=5511982023600

# URL canônica do site (sem barra no final)
# Usado em: canonical tag, Open Graph, Schema.org, sitemap.xml
# Formato: https://seudominioreal.com.br
NEXT_PUBLIC_BASE_URL=https://divelovers.com.br
